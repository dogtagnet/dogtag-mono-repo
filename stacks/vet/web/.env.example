# Vet portal env (copy to .env.local)

# Vet backend base URL used by the API client (via the Vite /api proxy by default).
VITE_VET_API_BASE=/api

# Central admin API base — the whitelist-apply posts issuer-applications here.
# In dev this can be proxied or pointed straight at the central API origin.
VITE_CENTRAL_API_BASE=http://localhost:41870

# Dev proxy target for /api (the vet backend). Defaults to http://localhost:41874.
VITE_VET_API_PROXY=http://localhost:41874

# Reown Cloud projectId for WalletConnect (REQUIRED for real wallet-connect).
# A placeholder is used if unset; WalletConnect transport will not function until set.
VITE_REOWN_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID

# Optional: the deployment URL shown in share/verify QR captions.
VITE_DEPLOYMENT_URL=http://localhost:41873

# ROAX RPC + deployed contract addresses (contracts/deployments/roax.json). The issue-status panel
# polls DogTagIssuer.isValid(merkleRoot) via viem to surface "Verified on-chain". In wallet mode the
# issuer address comes from the prepare response (unsignedTx.to); in backend mode set
# VITE_DOGTAG_ISSUER_ADDR to the per-recordType DogTagIssuer to enable live polling.
VITE_ROAX_RPC=https://devrpc.roax.net
VITE_DOGTAG_ISSUER_ADDR=
VITE_ISSUER_REGISTRY_ADDR=0x5d86e4CF98A34Ae0576F190F8d209c2943a9C79c
VITE_DOGTAG_SBT_ADDR=0x1FB8986573Ac36d532cF7d5a5352202B094D4233
VITE_VERIFICATION_REGISTRY_ADDR=0x19C1B5f80c41EE864149500bdF998Dd18aec2a43
VITE_POSEIDON6_ADDR=0x58091F2320c78ed6c6D1C02CB7E5c7578f1349db

# Demo mode (default OFF). When set to 1 (or "true"), the portal prefills forms, shows
# "Fill demo data" / "Demo (vet/groomer)" buttons, and autofills the demo admin password /
# passphrase. NEVER enable in production — in demo mode the vet genesis seed is briefly stashed
# in sessionStorage to auto-fill the confirm step. Unset = secure production behavior.
# VITE_DEMO_MODE=1
