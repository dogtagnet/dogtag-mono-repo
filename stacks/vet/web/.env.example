# Vet portal env (copy to .env.local)

# Vet backend base URL used by the API client (via the Vite /api proxy by default).
VITE_VET_API_BASE=/api

# Central admin API base — the whitelist-apply posts issuer-applications here.
# In dev this can be proxied or pointed straight at the central API origin.
VITE_CENTRAL_API_BASE=http://localhost:41870

# Dev proxy target for /api (the vet backend). Defaults to http://localhost:41874.
VITE_VET_API_PROXY=http://localhost:41874

# Reown Cloud projectId for WalletConnect (REQUIRED for real wallet-connect).
# A placeholder is used if unset; WalletConnect transport will not function until set.
VITE_REOWN_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID

# Optional: the deployment URL shown in share/verify QR captions.
VITE_DEPLOYMENT_URL=http://localhost:41873
