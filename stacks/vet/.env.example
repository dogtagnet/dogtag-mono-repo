# ---- DogTag VET stack env (impl §7). Copy to `.env` and fill in. ----
# Chain
ROAX_RPC=https://devrpc.roax.net
ROAX_CHAIN_ID=135

# Mongo — INTERNAL to the compose network only (service name `mongo`, port 41875). Never published.
MONGO_URI=mongodb://mongo:41875/dogtag

# This deployment's public identity (used for DNS-TXT issuer binding + JWT issuer claim).
DEPLOYMENT_URL=https://vet.example.com
DEPLOYMENT_DOMAIN=vet.example.com
ISSUER_NAME=Example Veterinary Clinic
ISSUER_DOMAIN=vet.example.com

# On-chain addresses (from deployments/roax.json after Deploy.s.sol).
ISSUER_REGISTRY_ADDR=0x0000000000000000000000000000000000000000
VERIFICATION_REGISTRY_ADDR=0x0000000000000000000000000000000000000000
VACCINATION_ISSUER_ADDR=0x0000000000000000000000000000000000000000

# Custody — age-encrypted seed path (mounted volume) + portal passwords.
KEYSTORE_PATH=/data/seed.age
OPERATOR_PASSWORD=change-me-operator
ADMIN_PASSWORD=change-me-admin

# Confirmations to wait at /credentials/confirm (reorg-safety).
CONFIRMATIONS=2

# Central registry wiring (HMAC-shared, appointment source-of-truth).
BUSINESS_ID=biz-vet-local
CENTRAL_BASE_URL=https://api.dogtag.io
CENTRAL_HMAC_SECRET=change-me-central-hmac

# Optional: point at the circuits build dir to load the REAL Groth16 prover (else StubProver).
# CIRCUITS_BUILD_DIR=/circuits/build

# Google Calendar OAuth (Phase 7).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary
