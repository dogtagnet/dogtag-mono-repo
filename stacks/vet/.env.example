# ==============================================================================================
# DogTag — VET stack env (REMOTE / PRODUCTION template). Copy to `.env` and fill in.
# ----------------------------------------------------------------------------------------------
# Local/demo uses scripts/demo-up.sh (MemStore, DNS_CHECK=skip, demo passwords) — it does NOT read
# this file. This file is the REMOTE/production template, consumed by stacks/vet/docker-compose.yml
# (and scripts/remote-up.sh). To target a DIFFERENT chain, change ROAX_RPC + CHAIN_ID + the *_ADDR
# addresses below — no code edits.
# ==============================================================================================

# ---- Chain (config-only swap to a different chain) -------------------------------------------
ROAX_RPC=https://devrpc.roax.net
CHAIN_ID=135

# ---- Persistent store (Mongo) ----------------------------------------------------------------
# Custody (age-encrypted seed) + records live here — BACK UP the Mongo data volume. The api
# fail-closes (refuses to boot) if it cannot connect. In compose, MONGO_URI is set to the internal
# `mongo` service; override here only for an external/managed Mongo.
MONGO_URI=mongodb://mongo:27017/dogtag
MONGO_DB=dogtag

# ---- Listener ports --------------------------------------------------------------------------
PORT=41874
# ADMIN_PORT defaults to PORT+1; the /admin/* router binds here when ADMIN_LOOPBACK_ONLY=1.
# ADMIN_PORT=41875

# ---- This deployment's public identity (DNS-TXT issuer binding + JWT issuer claim) -----------
DEPLOYMENT_URL=https://vet.example.com
DEPLOYMENT_DOMAIN=vet.example.com
ISSUER_NAME=Example Veterinary Clinic
ISSUER_DOMAIN=vet.example.com

# ---- On-chain addresses (from contracts/deployments/roax.json) -------------------------------
ISSUER_REGISTRY_ADDR=0x5d86e4CF98A34Ae0576F190F8d209c2943a9C79c
VERIFICATION_REGISTRY_ADDR=0x19C1B5f80c41EE864149500bdF998Dd18aec2a43
VACCINATION_ISSUER_ADDR=0x0000000000000000000000000000000000000000

# ---- Hardening (production values) -----------------------------------------------------------
DNS_CHECK=doh                 # real issuer-domain legitimacy via Cloudflare DoH (demo uses `skip`)
CONFIRMATIONS=2               # reorg-safety at /credentials/confirm (demo uses 1)
ADMIN_LOOPBACK_ONLY=1         # bind /admin/* custody routes to 127.0.0.1:ADMIN_PORT only
# CORS allowlist (comma-separated origins). Unset => permissive (demo only).
CORS_ALLOW_ORIGINS=https://vet.example.com

# ---- Secrets (generate strong values — do NOT reuse the demo defaults) -----------------------
OPERATOR_PASSWORD=        # generate: openssl rand -hex 32
ADMIN_PASSWORD=           # generate: openssl rand -hex 32
CENTRAL_HMAC_SECRET=      # generate: openssl rand -hex 32  (must match central's CENTRAL_HMAC_SECRET)

# ---- Caddy TLS reverse-proxy -----------------------------------------------------------------
# Public hostname Caddy issues a Let's Encrypt cert for. Needs a DNS A record + open ports 80/443.
DOMAIN=vet.example.com

# ---- Central registry wiring (HMAC-shared appointment source-of-truth) -----------------------
BUSINESS_ID=biz-vet-local
CENTRAL_BASE_URL=https://api.dogtag.io

# ---- Optional: point at the circuits build dir for the REAL Groth16 prover (else StubProver) --
# CIRCUITS_BUILD_DIR=/circuits/build

# ---- Google Calendar OAuth (Phase 7) ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary
