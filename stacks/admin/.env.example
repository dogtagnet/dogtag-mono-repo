# ---- DogTag ADMIN / CENTRAL stack env (impl §7). Copy to `.env` and fill in. ----
# Chain
ROAX_RPC=https://devrpc.roax.net
ROAX_CHAIN_ID=135

# Mongo — INTERNAL to the compose network only (service name `mongo`, port 39743). Never published.
MONGO_URI=mongodb://mongo:39743/dogtag

# Central deployment identity.
DEPLOYMENT_URL=https://api.dogtag.io
ISSUER_NAME=DogTag Central
ISSUER_DOMAIN=dogtag.io

# On-chain addresses (from deployments/roax.json after Deploy.s.sol).
ISSUER_REGISTRY_ADDR=0x0000000000000000000000000000000000000000
SBT_ADDR=0x0000000000000000000000000000000000000000

# Admin protocol signer (whitelistFor / SBT mint) — custody index + admin-session password.
ADMIN_SIGNER_INDEX=0
ADMIN_PASSWORD=change-me-admin
KEYSTORE_PATH=/data/seed.age

# Shared HMAC secret with business backends (appointment-events authentication).
CENTRAL_HMAC_SECRET=change-me-central-hmac
