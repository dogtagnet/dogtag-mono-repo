# ==============================================================================================
# DogTag — ADMIN / CENTRAL stack env (REMOTE / PRODUCTION template). Copy to `.env` and fill in.
# ----------------------------------------------------------------------------------------------
# Local/demo uses scripts/demo-up.sh (MemStore, DNS_CHECK=skip, demo passwords) — it does NOT read
# this file. This file is the REMOTE/production template, consumed by
# stacks/admin/docker-compose.yml (and scripts/remote-up.sh). To target a DIFFERENT chain, change
# ROAX_RPC + CHAIN_ID + the *_ADDR addresses below — no code edits.
# ==============================================================================================

# ---- Chain (config-only swap to a different chain) -------------------------------------------
ROAX_RPC=https://devrpc.roax.net
CHAIN_ID=135

# ---- Persistent store (Mongo) ----------------------------------------------------------------
# Custody (age-encrypted admin signer seed) + records live here — BACK UP the Mongo data volume.
# The api fail-closes (refuses to boot) if it cannot connect.
MONGO_URI=mongodb://mongo:27017/dogtag
MONGO_DB=dogtag

# ---- Listener ports --------------------------------------------------------------------------
PORT=39742
# ADMIN_PORT defaults to PORT+1; the /admin/* router binds here when ADMIN_LOOPBACK_ONLY=1.
# ADMIN_PORT=39743

# ---- Central deployment identity -------------------------------------------------------------
DEPLOYMENT_URL=https://api.dogtag.io
ISSUER_NAME=DogTag Central
ISSUER_DOMAIN=dogtag.io

# ---- On-chain addresses (from contracts/deployments/roax.json) -------------------------------
ISSUER_REGISTRY_ADDR=0x5d86e4CF98A34Ae0576F190F8d209c2943a9C79c
SBT_ADDR=0x1FB8986573Ac36d532cF7d5a5352202B094D4233
PROFILE_DOCUMENT_STORE=0x1FB8986573Ac36d532cF7d5a5352202B094D4233

# ---- Admin protocol signer (whitelistFor / SBT mint) -----------------------------------------
ADMIN_SIGNER_INDEX=0

# ---- Hardening (production values) -----------------------------------------------------------
DNS_CHECK=doh                 # real issuer-domain legitimacy via Cloudflare DoH (demo uses `skip`)
CONFIRMATIONS=2               # reorg-safety (demo uses 1)
ADMIN_LOOPBACK_ONLY=1         # bind /admin/* custody routes to 127.0.0.1:ADMIN_PORT only
CORS_ALLOW_ORIGINS=https://api.dogtag.io

# ---- Secrets (generate strong values — do NOT reuse the demo defaults) -----------------------
ADMIN_PASSWORD=           # generate: openssl rand -hex 32  (admin-session password)
CENTRAL_HMAC_SECRET=      # generate: openssl rand -hex 32  (shared with every business backend)
# Dedicated FUNDED EOA that signs whitelistFor / SBT-mint on-chain. Keep this key secret.
ADMIN_PRIVATE_KEY=        # 0x-prefixed 32-byte hex private key of a funded signer
ADMIN_ADDRESS=            # the 0x address derived from ADMIN_PRIVATE_KEY

# ---- Caddy TLS reverse-proxy -----------------------------------------------------------------
# Public hostname Caddy issues a Let's Encrypt cert for. Needs a DNS A record + open ports 80/443.
DOMAIN=api.dogtag.io
