# Admin portal env (copy to .env.local)

# Central admin API base used by the central client (via the Vite /api proxy by default).
VITE_CENTRAL_API_BASE=/api

# Dev proxy target for /api (the central backend). Defaults to http://localhost:39742.
VITE_CENTRAL_API_PROXY=http://localhost:39742

# Reown Cloud projectId for WalletConnect (the admin portal uses the shared wallet provider for
# theming/StatusPanel parity; a placeholder is fine if you don't connect a wallet here).
VITE_REOWN_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID

# Optional: deployment URL.
VITE_DEPLOYMENT_URL=http://localhost:39741

# ROAX RPC (read on-chain whitelist / isValid state). Default ROAX devrpc.
VITE_ROAX_RPC=https://devrpc.roax.net

# Deployed ROAX contract addresses (contracts/deployments/roax.json). The whitelist viewer reads
# IssuerRegistry.isWhitelistedFor(bytes32,address) directly via viem when the registry is set;
# otherwise it falls back to deriving state from approved issuer-applications.
VITE_ISSUER_REGISTRY_ADDR=0x5d86e4CF98A34Ae0576F190F8d209c2943a9C79c
VITE_DOGTAG_SBT_ADDR=0x1FB8986573Ac36d532cF7d5a5352202B094D4233
VITE_VERIFICATION_REGISTRY_ADDR=0x8bA836eCe9a27c43049aCcC26eB5a1579c1FcFA1
VITE_POSEIDON6_ADDR=0x58091F2320c78ed6c6D1C02CB7E5c7578f1349db

# Demo mode (default OFF). When set to 1 (or "true"), the portal prefills forms, shows
# "Fill demo data" / "Demo (vet/groomer)" buttons, and autofills the demo admin password /
# passphrase. NEVER enable in production — in demo mode the vet genesis seed is briefly stashed
# in sessionStorage to auto-fill the confirm step. Unset = secure production behavior.
# VITE_DEMO_MODE=1
