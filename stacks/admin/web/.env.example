# Admin portal env (copy to .env.local)

# Central admin API base used by the central client (via the Vite /api proxy by default).
VITE_CENTRAL_API_BASE=/api

# Dev proxy target for /api (the central backend). Defaults to http://localhost:39742.
VITE_CENTRAL_API_PROXY=http://localhost:39742

# Reown Cloud projectId for WalletConnect (the admin portal uses the shared wallet provider for
# theming/StatusPanel parity; a placeholder is fine if you don't connect a wallet here).
VITE_REOWN_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID

# Optional: deployment URL.
VITE_DEPLOYMENT_URL=http://localhost:39741

# Whitelist viewer reads on-chain IssuerRegistry.isWhitelistedFor(bytes32,address) directly via
# viem. Set the deployed IssuerRegistry address and (optionally) a ROAX RPC override. If unset, the
# viewer falls back to deriving whitelist state from approved issuer-applications.
VITE_ISSUER_REGISTRY_ADDR=
VITE_ROAX_RPC=https://devrpc.roax.net
