# ==============================================================================================
# DogTag — GOVERNMENT stack env (REMOTE / PRODUCTION template). Copy to `.env` and fill in.
# ----------------------------------------------------------------------------------------------
# The government credential authority issues authority-endorsed TRAVEL_CLEARANCE / EU_HEALTH_CERT
# credentials and records government-grade verifications against the ROAX contracts. It is a
# SEPARATE deployable (own docker-compose, own Mongo, own signer) — see docs/ROLE_APPS.md.
#
# Local/demo: set GOV_DEMO_MODE=1 (MemChain + MemStore, no node, no gas). This file is the
# REMOTE/production template, consumed by stacks/government/docker-compose.yml. To target a
# DIFFERENT chain, change ROAX_RPC + CHAIN_ID + the *_ADDR addresses below — no code edits.
# ==============================================================================================

# ---- Chain (config-only swap to a different chain) -------------------------------------------
ROAX_RPC=https://devrpc.roax.net
CHAIN_ID=135

# ---- Persistent store (Mongo, internal to the compose network only) --------------------------
MONGO_URI=mongodb://mongo:27017/dogtag
MONGO_DB=dogtag

# ---- Listener port ---------------------------------------------------------------------------
PORT=44832

# ---- This deployment's public identity (issuer binding) --------------------------------------
DEPLOYMENT_URL=https://gov.example.com
ISSUER_NAME=Example Competent Authority
ISSUER_DOMAIN=gov.example.com

# ---- On-chain addresses (from contracts/deployments/roax.json) -------------------------------
# IssuerRegistry is the whitelist gate (read for the issuer-identity verification pillar).
ISSUER_REGISTRY_ADDR=0x5d86e4CF98A34Ae0576F190F8d209c2943a9C79c
# DogTagIssuer clones this authority anchors roots to. These are per-record-type clones deployed
# via the existing DogTagIssuerFactory (an OPS step — no contract change). Leave zero to disable
# on-chain issuance for that record type (build+persist still works via dry_run). See ROLE_APPS.md.
TRAVEL_CLEARANCE_ISSUER_ADDR=0x0000000000000000000000000000000000000000
EU_HEALTH_CERT_ISSUER_ADDR=0x0000000000000000000000000000000000000000

# ---- Government signer (32-byte secp256k1 private key, 0x-optional hex) -----------------------
# Required to anchor roots on-chain (DogTagIssuer.issue). This address must hold the record type's
# issuance whitelist (IssuerRegistry.whitelistFor, granted by the protocol admin) and be funded
# with PLASMA gas. Reads (verify) work without it. NEVER commit a real key.
GOV_SIGNER_KEY=

# ---- Demo toggle -----------------------------------------------------------------------------
# GOV_DEMO_MODE=1 uses the in-memory MemChain + MemStore (no node, no gas, no Mongo). Leave UNSET
# in production.
# GOV_DEMO_MODE=1

# ---- Hardening (production values) -----------------------------------------------------------
# CORS allowlist (comma-separated origins). Unset => permissive (demo only).
CORS_ALLOW_ORIGINS=https://gov.example.com
# Bearer token gating the record MUTATION endpoints (PATCH /v1/records/:root and
# POST /v1/records/:root/revoke). Reads/verify/issue stay open. Unset in production => mutations
# fail closed (503). In demo mode an unset token defaults to `dogtag-gov-demo-token` (the portal's
# VITE_GOV_API_TOKEN falls back to the same value).
GOV_API_TOKEN=

# ---- Caddy TLS reverse-proxy -----------------------------------------------------------------
DOMAIN=gov.example.com
