# ---- DogTag GROOMER stack env (impl §7). Copy to `.env` and fill in. ----
# The groomer backend IS the vet-api binary run with BUSINESS_TYPE=groomer.
BUSINESS_TYPE=groomer

# Chain
ROAX_RPC=https://devrpc.roax.net
ROAX_CHAIN_ID=135

# Mongo — INTERNAL to the compose network only (service name `mongo`, port 43619). Never published.
MONGO_URI=mongodb://mongo:43619/dogtag

# This deployment's public identity.
DEPLOYMENT_URL=https://groomer.example.com
DEPLOYMENT_DOMAIN=groomer.example.com
ISSUER_NAME=Example Grooming Salon
ISSUER_DOMAIN=groomer.example.com

# On-chain addresses (a groomer is typically a VERIFIER, so issuer-clone addrs may be unset).
ISSUER_REGISTRY_ADDR=0x0000000000000000000000000000000000000000
VERIFICATION_REGISTRY_ADDR=0x0000000000000000000000000000000000000000
VACCINATION_ISSUER_ADDR=0x0000000000000000000000000000000000000000

# Custody + portal passwords.
KEYSTORE_PATH=/data/seed.age
OPERATOR_PASSWORD=change-me-operator
ADMIN_PASSWORD=change-me-admin
CONFIRMATIONS=2

# Central registry wiring.
BUSINESS_ID=biz-groomer-local
CENTRAL_BASE_URL=https://api.dogtag.io
CENTRAL_HMAC_SECRET=change-me-central-hmac

# Google Calendar OAuth (Phase 7).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary
