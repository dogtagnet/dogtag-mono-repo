# Groomer portal env (copy to .env.local)

# Groomer backend base URL used by the API client (via the Vite /api proxy by default).
# The groomer backend is structurally identical to the vet backend (same routes.rs contracts).
VITE_GROOMER_API_BASE=/api

# Central admin API base — the whitelist-apply posts issuer-applications here.
VITE_CENTRAL_API_BASE=http://localhost:39742

# Dev proxy target for /api (the groomer backend). Defaults to http://localhost:43618.
VITE_GROOMER_API_PROXY=http://localhost:43618

# Reown Cloud projectId for WalletConnect (REQUIRED for real wallet-connect).
# A placeholder is used if unset; WalletConnect transport will not function until set.
VITE_REOWN_PROJECT_ID=REPLACE_WITH_REOWN_PROJECT_ID

# Optional: the deployment URL shown in share/verify QR captions.
VITE_DEPLOYMENT_URL=http://localhost:43617
