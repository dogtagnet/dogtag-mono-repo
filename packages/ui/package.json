{
  "name": "@dogtag/ui",
  "version": "0.0.0",
  "description": "DogTag shared portal UI library — semantic-token theming, shadcn-style primitives, wallet-connect, verify flow (reference impl for vet/groomer/admin portals)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind-preset": {
      "types": "./src/tailwind-preset.ts",
      "import": "./src/tailwind-preset.ts",
      "require": "./src/tailwind-preset.ts",
      "default": "./src/tailwind-preset.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@dogtag/standard": "workspace:*",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "1.2.6",
    "@reown/appkit": "1.6.8",
    "@reown/appkit-adapter-wagmi": "1.6.8",
    "@tanstack/react-query": "5.66.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",
    "qrcode.react": "4.2.0",
    "tailwind-merge": "2.6.0",
    "viem": "2.23.11",
    "wagmi": "2.14.15"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.6.3"
  }
}
