{
  "name": "@dogtag/standard",
  "version": "0.0.0",
  "description": "DogTag open pet-credential standard — canonicalization, Poseidon Merkle, verify, consent (TS SDK, mirror of dogtag-standard-rs)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "gen-vectors": "tsx scripts/gen-testvectors.ts",
    "gen-consent-vectors": "tsx scripts/gen-consent-vectors.ts"
  },
  "dependencies": {
    "@noble/hashes": "1.5.0",
    "circomlibjs": "0.1.7",
    "poseidon-lite": "0.3.0"
  },
  "devDependencies": {
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
