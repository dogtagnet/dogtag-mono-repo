{
  "name": "@dogtag/circuits",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "DogTag Groth16 circuit + the NORMATIVE Poseidon 4-language parity gate (Gate A)",
  "scripts": {
    "parity": "node scripts/gen-vectors.mjs",
    "gen-vectors": "node scripts/gen-vectors.mjs",
    "compile-circuit": "circom verification.circom --r1cs --wasm --sym -l node_modules/circomlib/circuits -o build",
    "build-circuit": "bash scripts/setup.sh",
    "test-circuit": "node scripts/test-circuit.mjs"
  },
  "dependencies": {
    "circomlib": "2.0.5",
    "circomlibjs": "0.1.7",
    "poseidon-lite": "0.3.0",
    "snarkjs": "0.7.6"
  }
}
